# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_PASSWORD=changeme_supersecret

# ── NextAuth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme_generate_a_real_secret
NEXTAUTH_URL=http://localhost:3000

# ── Admin credentials ────────────────────────────────────
ADMIN_USERNAME=nicolas
ADMIN_PASSWORD=changeme_strong_password

# ── Ollama AI Agent ──────────────────────────────────────
# URL del servicio Ollama (en Docker usa el nombre del servicio)
OLLAMA_URL=http://ollama:11434
# Modelo Gemma 4: e2b (2B params) o e4b (4B params, mejor calidad)
OLLAMA_MODEL=gemma4:e4b
